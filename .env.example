# Kopiere diese Datei nach .env.local und fülle die Werte aus

# ── Allgemein ────────────────────────────────────────────────
# Deine öffentliche Domain (ohne abschließenden Slash)
NEXT_PUBLIC_SITE_URL=https://deine-domain.de

# ── Supabase ─────────────────────────────────────────────────
# Zu finden unter: Supabase Dashboard > Project Settings > API

# Öffentliche URL deines Supabase-Projekts
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon / Public Key (sicher für den Browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-Role Key – NUR server-seitig, NIEMALS im Browser!
# Zu finden unter: Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Optional: Analytics ───────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
